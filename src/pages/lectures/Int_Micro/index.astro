---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = '/lectures/Int_Micro';

const weeks = [
    {
        title: 'Week 1',
        summary: 'Building the demand and supply curves from primitives across a five-day arc: preferences, optimisation, demand, production, and cost & supply.',
        days: [
            {
                day: 'Day 1',
                topic: 'Preferences and Utility Functions',
                desc: 'What the consumer wants: indifference curves, the marginal rate of substitution, and utility as an ordinal representation of preferences. (Perloff Ch. 3)',
                slides: `${base}/Week1/Week1_Day1.pdf`,
                ps: { name: 'Problem Set 1 — Preferences', href: `${base}/Week1_ProblemSet/EC306_PS1_Preferences.pdf` }
            },
            {
                day: 'Day 2',
                topic: 'The Constrained Optimisation Problem',
                desc: 'What the consumer can afford: the budget line and solving max u(x, y) subject to the budget to pin down the chosen bundle. (Perloff Ch. 4)',
                slides: `${base}/Week1/Week1_Day2.pdf`,
                ps: { name: 'Problem Set 2 — Optimisation', href: `${base}/Week1_ProblemSet/EC306_PS2_Optimisation.pdf` }
            },
            {
                day: 'Day 3',
                topic: 'Demand: Hicks, Slutsky, and Elasticity',
                desc: 'Marshallian vs Hicksian (compensated) demand and the expenditure function, the Slutsky substitution/income decomposition, and elasticities. (Perloff Ch. 5, §2.3)',
                slides: `${base}/Week1/Week1_Day3.pdf`,
                ps: { name: 'Problem Set 3 — Demand', href: `${base}/Week1_ProblemSet/EC306_PS3_Demand.pdf` }
            },
            {
                day: 'Day 4',
                topic: 'Firms, Production, and Production Functions',
                desc: "Crossing to the supply side: the firm's technology — production functions, isoquants, MRTS — and its structural parallel with consumer theory. (Perloff Ch. 6)",
                slides: `${base}/Week1/Week1_Day4.pdf`,
                ps: { name: 'Problem Set 4 — Production', href: `${base}/Week1_ProblemSet/EC306_PS4_Production.pdf` }
            },
            {
                day: 'Day 5',
                topic: "Costs and the Firm's Supply Curve",
                desc: 'Input prices and cost minimisation, the short-run cost curves, and profit maximisation to derive the supply curve — completing the demand–supply diagram from first principles. (Perloff Ch. 7, §8.1–8.4)',
                slides: `${base}/Week1/Week1_Day5.pdf`,
                ps: { name: 'Problem Set 5 — Costs & Supply', href: `${base}/Week1_ProblemSet/EC306_PS5_Costs_Supply.pdf` }
            }
        ]
    },
    {
        title: 'Week 2',
        summary: 'From market structure to strategic interaction: competitive equilibrium, monopoly pricing, oligopoly, and game-theoretic reasoning.',
        days: [
            {
                day: 'Day 1',
                topic: 'Competitive Markets and Long-Run Equilibrium',
                desc: 'How competitive firms make output decisions, the long-run adjustment to zero profit, and how market supply emerges from individual firm behaviour. (Perloff Ch. 8–9)',
                slides: `${base}/Week2/day1_slides.pdf`,
                ps: { name: 'Problem Set 1', href: `${base}/Week2_ProblemSet/day1_exercises.pdf` }
            },
            {
                day: 'Day 2',
                topic: 'Monopoly and Market Power',
                desc: 'The price-making firm: profit-maximising output, the markup over marginal cost, deadweight loss, and price discrimination. (Perloff Ch. 11–12)',
                slides: `${base}/Week2/day2_slides.pdf`,
                ps: { name: 'Problem Set 2', href: `${base}/Week2_ProblemSet/day2_exercises.pdf` }
            },
            {
                day: 'Day 3',
                topic: 'Oligopoly and Strategic Behaviour',
                desc: 'When a small number of firms interact: Cournot and Bertrand competition, best-response functions, and Nash equilibrium. (Perloff Ch. 14)',
                slides: `${base}/Week2/day3_slides.pdf`,
                ps: { name: 'Problem Set 3', href: `${base}/Week2_ProblemSet/day3_exercises.pdf` }
            },
            {
                day: 'Day 4',
                topic: 'Externalities, Public Goods, and Market Failure',
                desc: 'When markets fail: negative and positive externalities, Pigouvian taxes, the Coase theorem, and the provision of public goods. (Perloff Ch. 17–18)',
                slides: `${base}/Week2/day4_slides.pdf`,
                ps: { name: 'Problem Set 4', href: `${base}/Week2_ProblemSet/day4_exercises.pdf` }
            }
        ]
    }
];
---

<BaseLayout
    title="Intermediate Microeconomics"
    description="Lecture slides, weekly problem sets, and module handbook for Intermediate Microeconomics."
>
    <section class="page-hero">
        <div class="container">
            <p class="eyebrow">EC306 · Undergraduate · 2026</p>
            <h1>Intermediate Microeconomics</h1>
            <p>
                Consumer and producer theory, market structure, and welfare. Each session pairs lecture
                slides with a problem set for practice. Materials are added as the course runs.
            </p>
        </div>
    </section>

    <section class="section" style="padding-top: 1.5rem;">
        <div class="container">
            <article class="prose">
                <p><a href={`${base}/Module_Handbook.pdf`}>Module Handbook (PDF) →</a></p>

                <h2>Lecture materials</h2>
                {weeks.map((week) => (
                    <>
                        <h3>{week.title}</h3>
                        <p>{week.summary}</p>
                        <table class="toc">
                            <thead>
                                <tr><th>Day</th><th>Topic</th><th>Materials</th></tr>
                            </thead>
                            <tbody>
                                {week.days.map((d) => (
                                    <tr>
                                        <td class="toc-day">{d.day}</td>
                                        <td><strong>{d.topic}</strong><br />{d.desc}</td>
                                        <td class="toc-links">
                                            <a href={d.slides}>Slides (PDF)</a><br />
                                            <a href={d.ps.href}>{d.ps.name} (PDF)</a>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </>
                ))}
            </article>

            <p style="margin-top: 2.5rem;"><a class="backlink" href="/lectures">← All lecture notes</a></p>
        </div>
    </section>
</BaseLayout>

<style>
    .toc {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0 2rem;
        font-size: 0.95rem;
    }
    .toc th,
    .toc td {
        text-align: left;
        vertical-align: top;
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid var(--border, #e2e2e2);
    }
    .toc thead th {
        border-bottom-width: 2px;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .toc-day {
        white-space: nowrap;
        font-weight: 600;
    }
    .toc-links {
        white-space: nowrap;
    }
</style>
