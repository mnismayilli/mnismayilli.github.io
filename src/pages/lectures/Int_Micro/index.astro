---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = '/lectures/Int_Micro';

const weeks = [
    {
        title: 'Week 1',
        summary: 'Foundations of intermediate microeconomics.',
        slides: [
            { name: 'Day 1', href: `${base}/Week1/Week1_Day1.pdf` },
            { name: 'Day 2', href: `${base}/Week1/Week1_Day2.pdf` },
            { name: 'Day 3', href: `${base}/Week1/Week1_Day3.pdf` },
            { name: 'Day 4', href: `${base}/Week1/Week1_Day4.pdf` },
            { name: 'Day 5', href: `${base}/Week1/Week1_Day5.pdf` }
        ],
        problemSets: [
            { name: 'Problem Set 1 — Preferences', href: `${base}/Week1_ProblemSet/EC306_PS1_Preferences.pdf` },
            { name: 'Problem Set 2 — Optimisation', href: `${base}/Week1_ProblemSet/EC306_PS2_Optimisation.pdf` },
            { name: 'Problem Set 3 — Demand', href: `${base}/Week1_ProblemSet/EC306_PS3_Demand.pdf` },
            { name: 'Problem Set 4 — Production', href: `${base}/Week1_ProblemSet/EC306_PS4_Production.pdf` },
            { name: 'Problem Set 5 — Costs & Supply', href: `${base}/Week1_ProblemSet/EC306_PS5_Costs_Supply.pdf` }
        ]
    }
];
---

<BaseLayout
    title="Intermediate Microeconomics"
    description="Lecture slides, weekly problem sets, and module handbook for Intermediate Microeconomics."
>
    <section class="page-hero">
        <div class="container">
            <p class="eyebrow">EC306 · SJTU Summer School · 2026</p>
            <h1>Intermediate Microeconomics</h1>
            <p>
                Consumer and producer theory, market structure, and welfare. Each session pairs lecture
                slides with a problem set for practice. Materials are added as the course runs.
            </p>
        </div>
    </section>

    <section class="section" style="padding-top: 1.5rem;">
        <div class="container">
            <article class="prose">
                <p><a href={`${base}/Module_Handbook.pdf`}>Module Handbook (PDF) →</a></p>

                <h2>Lecture materials</h2>
                {weeks.map((week) => (
                    <>
                        <h3>{week.title}</h3>
                        <p>{week.summary}</p>
                        <h4>Lecture slides</h4>
                        <ul>
                            {week.slides.map((slide) => (
                                <li><a href={slide.href}>{slide.name} — Slides (PDF)</a></li>
                            ))}
                        </ul>
                        <h4>Problem sets</h4>
                        <ul>
                            {week.problemSets.map((ps) => (
                                <li><a href={ps.href}>{ps.name} (PDF)</a></li>
                            ))}
                        </ul>
                    </>
                ))}
            </article>

            <p style="margin-top: 2.5rem;"><a class="backlink" href="/lectures">← All lecture notes</a></p>
        </div>
    </section>
</BaseLayout>
