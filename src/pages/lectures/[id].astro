---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PostPreview from '../../components/PostPreview.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import { slugify } from '../../utils/common-utils';

export async function getStaticPaths() {
    const lectures = (await getCollection('lectures')).sort(sortItemsByDateDesc);
    const lectureCount = lectures.length;
    return lectures.map((lecture, index) => ({
        params: { id: lecture.id },
        props: {
            lecture,
            prevLecture: index + 1 !== lectureCount ? lectures[index + 1] : null,
            nextLecture: index !== 0 ? lectures[index - 1] : null
        }
    }));
}

type Props = { 
    lecture: CollectionEntry<'lectures'>; 
    prevLecture: CollectionEntry<'lectures'>; 
    nextLecture: CollectionEntry<'lectures'> 
};

const { lecture, prevLecture, nextLecture } = Astro.props;
const { title, publishDate, updatedDate, description, course, tags = [], seo } = lecture.data;
const { Content } = await render(lecture);
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? description} image={seo?.image} pageType="article">
    <section class="page-hero">
        <div class="container">
            <p class="eyebrow">
                <FormattedDate date={publishDate} />
                {updatedDate && <> · Updated <FormattedDate date={updatedDate} /></>}
                {course && <> · {course}</>}
            </p>
            <h1>{title}</h1>
        </div>
    </section>

    <section class="section" style="padding-top: 1.5rem;">
        <div class="container">
            <article class="prose">
                <Content />
            </article>
            {
                tags.length > 0 && (
                    <p style="margin-top: 2rem; display:flex; flex-wrap:wrap; gap:1rem;">
                        {tags.map((tag) => (
                            <a class="backlink" href={`/tags/${slugify(tag)}`}>#{tag}</a>
                        ))}
                    </p>
                )
            }
            <p style="margin-top: 2rem;"><a class="backlink" href="/lectures">← All lecture notes</a></p>
        </div>
    </section>

    {
        (prevLecture || nextLecture) && (
            <section class="section">
                <div class="container">
                    <div class="section-head reveal">
                        <div>
                            <p class="eyebrow">Keep reading</p>
                            <h2>More lecture notes</h2>
                        </div>
                    </div>
                    <div class="research-list">
                        {nextLecture && <PostPreview post={nextLecture} class="reveal" headingLevel="h3" urlPrefix="/lectures" />}
                        {prevLecture && <PostPreview post={prevLecture} class="reveal" headingLevel="h3" urlPrefix="/lectures" />}
                    </div>
                </div>
            </section>
        )
    }
</BaseLayout>
