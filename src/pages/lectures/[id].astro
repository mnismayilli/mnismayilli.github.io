---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PostPreview from '../../components/PostPreview.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import { slugify } from '../../utils/common-utils';

export async function getStaticPaths() {
    const lectures = (await getCollection('lectures')).sort(sortItemsByDateDesc);
    const lectureCount = lectures.length;
    return lectures.map((lecture, index) => ({
        params: { id: lecture.id },
        props: {
            lecture,
            prevLecture: index + 1 !== lectureCount ? lectures[index + 1] : null,
            nextLecture: index !== 0 ? lectures[index - 1] : null
        }
    }));
}

type Props = { 
    lecture: CollectionEntry<'lectures'>; 
    prevLecture: CollectionEntry<'lectures'>; 
    nextLecture: CollectionEntry<'lectures'> 
};

const { href } = Astro.url;
const { lecture, prevLecture, nextLecture } = Astro.props;
const { title, publishDate, updatedDate, description, course, tags = [], seo } = lecture.data;
const { Content } = await render(lecture);
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? description} image={seo?.image} pageType="article" showHeader={false}>
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="text-3xl leading-tight font-serif font-medium sm:text-5xl sm:leading-tight">{title}</h1>
            <div class="mt-4 text-sm flex flex-wrap items-center gap-4">
                <FormattedDate date={publishDate} />
                {
                    updatedDate && (
                        <span>
                            (Updated on <FormattedDate date={updatedDate} />)
                        </span>
                    )
                }
                {
                    course && (
                        <span class="px-2 py-1 bg-main/10 rounded text-main text-xs font-medium">
                            {course}
                        </span>
                    )
                }
            </div>
        </header>
        <div class="max-w-none prose sm:prose-lg">
            <Content />
        </div>
        <div class="mt-8 flex flex-wrap items-center gap-6 text-sm justify-between sm:mt-12 sm:text-base">
            {
                tags.length > 0 && (
                    <div class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
                        {tags.map((tag) => (
                            <a class="text-main hover:underline" href={`/tags/${slugify(tag)}`}>
                                #{tag}
                            </a>
                        ))}
                    </div>
                )
            }
            <Button class="copy-url-button" aria-label="Copy link" data-url={href} data-tooltip-default="Copy link" data-tooltip-success="Copied">Share</Button>
        </div>
    </article>
    {
        (prevLecture || nextLecture) && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 text-xl font-serif italic sm:mb-16 sm:text-2xl">More Lecture Notes</h2>
                {nextLecture && <PostPreview post={nextLecture} class="mb-10 sm:mb-12" headingLevel="h3" urlPrefix="/lectures" />}
                {prevLecture && <PostPreview post={prevLecture} class="mb-10 sm:mb-12" headingLevel="h3" urlPrefix="/lectures" />}
            </div>
        )
    }
</BaseLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const copyUrlButton = document.querySelector('.copy-url-button') as HTMLButtonElement;
        copyUrlButton?.addEventListener('click', async () => {
            await copyUrl(copyUrlButton);
        });

        async function copyUrl(button: HTMLButtonElement) {
            let url = button.getAttribute('data-url') || '';
            let label = button.innerText;

            await navigator.clipboard.writeText(url);

            button.innerText = 'Copied';

            setTimeout(() => {
                button.innerText = label;
            }, 2500);
        }
    });
</script>
