---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCourses } from '../../utils/lectures';

const courses = getCourses();
---

<BaseLayout title="Lecture Notes" description="Lecture notes, slides, and problem sets from my courses.">
    <section class="page-hero">
        <div class="container">
            <p class="eyebrow">Teaching materials · Open access</p>
            <h1>Lecture Notes</h1>
            <p>
                Lecture slides, hands-on R supplements, and problem sets for the courses I teach. Materials
                are added as each course runs — browse the courses below.
            </p>
        </div>
    </section>

    <section class="section" style="padding-top: 2rem;">
        <div class="container">
            <div class="card-grid">
                {
                    courses.map((course) => (
                        <a class="card reveal" href={course.href}>
                            <span class="card-kicker">{course.code} · {course.level}</span>
                            <h3>{course.title}</h3>
                            <p>{course.blurb}</p>
                            <span class="card-foot">Slides · problem sets →</span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>
</BaseLayout>
