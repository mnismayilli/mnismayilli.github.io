---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { courses } from '../../data/courses';
---

<BaseLayout title="Lecture Notes" description="Lecture notes, slides, and problem sets from my courses.">
    <section class="page-hero">
        <div class="container">
            <p class="eyebrow">Shanghai Jiao Tong University · Summer School</p>
            <h1>Lecture Notes</h1>
            <p>
                Lecture slides, hands-on R supplements, and problem sets for the courses I teach at the
                <strong>Summer School of Shanghai Jiao Tong University (SJTU)</strong>. Materials are added as
                each course runs — browse the courses below.
            </p>
        </div>
    </section>

    <section class="section" style="padding-top: 2rem;">
        <div class="container">
            <div class="card-grid">
                {
                    courses.map((course) => (
                        <a class="card reveal" href={course.href}>
                            <span class="card-kicker">{course.code} · {course.level}</span>
                            <h3>{course.title}</h3>
                            <p>{course.blurb}</p>
                            <span class="card-foot">Slides · problem sets →</span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>
</BaseLayout>
