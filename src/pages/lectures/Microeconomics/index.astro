---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = '/lectures/Microeconomics';

const weeks = [
    {
        title: 'Week 1',
        summary: 'Foundations of microeconomics: consumer choice, demand, firm behaviour, and competitive markets.',
        days: [
            {
                day: 'Day 1',
                topic: 'Ten Principles of Economics & Thinking Like an Economist',
                desc: 'What economics is: the ten principles, opportunity cost and marginal thinking, the production possibilities frontier, and the gains from trade through comparative advantage.',
                slides: `${base}/Week1/ec107-day1.pdf`,
                ps: { name: 'Problem Set 1', href: `${base}/Week1_ProblemSets/ec107_Day1_PS1.pdf` }
            },
            {
                day: 'Day 2',
                topic: 'The Market Forces of Supply and Demand',
                desc: 'How markets work: demand and supply, market equilibrium, and the comparative statics of price and quantity.',
                slides: `${base}/Week1/ec107-day2.pdf`,
                ps: { name: 'Problem Set 2', href: `${base}/Week1_ProblemSets/ec107_Day2_PS2.pdf` }
            },
            {
                day: 'Day 3',
                topic: 'Elasticity and Its Application',
                desc: 'Price elasticity of demand, its link to total revenue, other elasticities (income and cross-price), and common pitfalls.',
                slides: `${base}/Week1/ec107-day3.pdf`,
                ps: { name: 'Problem Set 3', href: `${base}/Week1_ProblemSets/ec107_Day3_PS3.pdf` }
            },
            {
                day: 'Day 4',
                topic: 'Supply, Demand, Government Policies, and the Efficiency of Markets',
                desc: 'Price controls, consumer and producer surplus, market efficiency, and the deadweight loss of taxes.',
                slides: `${base}/Week1/ec107-day4.pdf`,
                ps: { name: 'Problem Set 4', href: `${base}/Week1_ProblemSets/ec107_Day4_PS4.pdf` }
            }
        ]
    },
    {
        title: 'Week 2',
        summary: 'From the cost curves to market structure: costs of production, perfect competition, monopoly, and duopoly.',
        days: [
            {
                day: 'Day 1',
                topic: 'Costs of Production',
                desc: "Fixed, variable and total cost; the three per-unit curves (average fixed, average variable and average total cost) and marginal cost; the averaging rule that links marginal to average cost; and the distinction between short-run costs and the long-run average cost curve.",
                slides: `${base}/Week2/day1_slides.pdf`,
                ps: { name: 'Problem Set 1', href: `${base}/Week2_ProblemSets/day1_exercises.pdf` }
            },
            {
                day: 'Day 2',
                topic: 'Perfect Competition',
                desc: "The four features of a competitive market and why marginal revenue equals average revenue equals price for a price-taker; the profit-maximising rule MR = MC; the short-run shut-down rule when price fails to cover average variable cost; and long-run entry and exit that drive profit to zero.",
                slides: `${base}/Week2/day2_slides.pdf`,
                ps: { name: 'Problem Set 2', href: `${base}/Week2_ProblemSets/day2_exercises.pdf` }
            },
            {
                day: 'Day 3',
                topic: 'Monopoly',
                desc: "Sources of market power and why marginal revenue lies below price (the MR line has twice the slope of demand); the monopolist's MR = MC output, with lower quantity and higher price than under competition; the resulting deadweight loss; and price discrimination, first-degree and third-degree across separate markets.",
                slides: `${base}/Week2/day3_slides.pdf`,
                ps: { name: 'Problem Set 3', href: `${base}/Week2_ProblemSets/day3_exercises.pdf` }
            },
            {
                day: 'Day 4',
                topic: 'Duopoly: Two Firms',
                desc: 'Bertrand price competition and the pressure to undercut; Cournot quantity competition solved through reaction functions to a Nash equilibrium; the Stackelberg first-mover advantage; and a comparison of the four market structures on a common example.',
                slides: `${base}/Week2/day4_slides.pdf`,
                ps: { name: 'Problem Set 4', href: `${base}/Week2_ProblemSets/day4_exercises.pdf` }
            }
        ]
    }
];
---

<BaseLayout
    title="Microeconomics"
    description="Lecture slides, weekly problem sets, and module handbook for Microeconomics (EC107)."
>
    <section class="page-hero">
        <div class="container">
            <p class="eyebrow">EC107 · Undergraduate · 2026</p>
            <h1>Microeconomics</h1>
            <p>
                An introduction to microeconomic principles — consumer choice and demand, firm behaviour and
                costs, and competitive markets. Each session pairs lecture slides with a problem set for
                practice. Materials are added as the course runs.
            </p>
        </div>
    </section>

    <section class="section" style="padding-top: 1.5rem;">
        <div class="container">
            <article class="prose">
                <p><a href={`${base}/Handbook.pdf`}>Module Handbook (PDF) →</a></p>

                <h2>Lecture materials</h2>
                {weeks.map((week) => (
                    <>
                        <h3>{week.title}</h3>
                        <p>{week.summary}</p>
                        <table class="toc">
                            <thead>
                                <tr><th>Day</th><th>Topic</th><th>Materials</th></tr>
                            </thead>
                            <tbody>
                                {week.days.map((d) => (
                                    <tr>
                                        <td class="toc-day">{d.day}</td>
                                        <td><strong>{d.topic}</strong><br />{d.desc}</td>
                                        <td class="toc-links">
                                            <a href={d.slides}>Slides (PDF)</a><br />
                                            <a href={d.ps.href}>{d.ps.name} (PDF)</a>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </>
                ))}
            </article>

            <p style="margin-top: 2.5rem;"><a class="backlink" href="/lectures">← All lecture notes</a></p>
        </div>
    </section>
</BaseLayout>

<style>
    .toc {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0 2rem;
        font-size: 0.95rem;
    }
    .toc th,
    .toc td {
        text-align: left;
        vertical-align: top;
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid var(--border, #e2e2e2);
    }
    .toc thead th {
        border-bottom-width: 2px;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .toc-day {
        white-space: nowrap;
        font-weight: 600;
    }
    .toc-links {
        white-space: nowrap;
    }
</style>
