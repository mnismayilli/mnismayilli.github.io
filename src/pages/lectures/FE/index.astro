---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = '/lectures/FE';

const problemSets = [
    { name: 'Problem Set 1 (PDF)', href: `${base}/FI362_ProblemSet1.pdf` }
];

const datasets = [
    { name: 'Data-download script (R)', href: `${base}/data/download_data.R` },
    { name: 'Index prices — daily adjusted close', href: `${base}/data/indices_adjclose.csv` },
    { name: 'Index prices — monthly', href: `${base}/data/indices_monthly.csv` },
    { name: 'S&P 500 — monthly', href: `${base}/data/sp500_monthly.csv` },
    { name: 'Individual stocks — adjusted close', href: `${base}/data/stocks_adjclose.csv` },
    { name: 'Series metadata', href: `${base}/data/metadata.csv` }
];

const chapters = [
    {
        title: 'Chapter 1 — Introduction to Financial Econometrics',
        summary: 'Asset returns and the distributional properties of returns: simple vs log returns, fat tails, skewness, and non-normality tested on real market data.',
        slides: `${base}/FI362_Ch1.pdf`,
        supplement: `${base}/FI362_Ch1_Supplement.html`
    },
    {
        title: 'Chapter 2 — Linear Time Series Analysis and Its Applications',
        summary: 'Stationarity, serial correlation, ARMA modelling, model diagnostics, and forecasting with real data.',
        slides: `${base}/FI362_Ch2.pdf`,
        supplement: `${base}/FI362_Ch2_Supplement.html`
    }
];
---

<BaseLayout
    title="FI 362 · Advanced Financial Econometrics"
    description="Lecture notes, slides, R supplements, and data for FI 362 Advanced Financial Econometrics (Summer Intensive Module, 2026)."
>
    <section class="page-hero">
        <div class="container">
            <p class="eyebrow">FI362 · 29 June – 17 July 2026</p>
            <h1>Advanced Financial Econometrics</h1>
            <p>
                An introduction to the econometrics of financial markets: asset returns and their
                distributional properties, linear time-series models (ARMA), volatility modelling (GARCH),
                continuous-time processes for derivative pricing, and tail-risk measures (EVT and
                Value-at-Risk). Each chapter pairs lecture slides with a hands-on R supplement on real data.
            </p>
        </div>
    </section>

    <section class="section" style="padding-top: 1.5rem;">
        <div class="container">
            <article class="prose">
                <p><a href={`${base}/FI362_Module_Handbook.pdf`}>Module Handbook (PDF) →</a></p>

                <h2>Lecture materials</h2>
                <table class="toc">
                    <thead>
                        <tr><th>Chapter</th><th>Topic</th><th>Materials</th></tr>
                    </thead>
                    <tbody>
                        {chapters.map((ch) => (
                            <tr>
                                <td class="toc-day">{ch.title.split('—')[0].trim()}</td>
                                <td>
                                    <strong>{ch.title.split('—').slice(1).join('—').trim()}</strong><br />
                                    {ch.summary}
                                </td>
                                <td class="toc-links">
                                    <a href={ch.slides}>Slides (PDF)</a><br />
                                    <a href={ch.supplement}>R supplement (HTML)</a>
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>

                <h2>Problem sets</h2>
                <ul>
                    {problemSets.map((p) => (
                        <li><a href={p.href}>{p.name}</a></li>
                    ))}
                </ul>

                <h2>Data</h2>
                <p>Datasets used in the R supplements:</p>
                <ul>
                    {datasets.map((d) => (
                        <li><a href={d.href}>{d.name}</a></li>
                    ))}
                </ul>
            </article>

            <p style="margin-top: 2.5rem;"><a class="backlink" href="/lectures">← All lecture notes</a></p>
        </div>
    </section>
</BaseLayout>

<style>
    .toc {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0 2rem;
        font-size: 0.95rem;
    }
    .toc th,
    .toc td {
        text-align: left;
        vertical-align: top;
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid var(--border, #e2e2e2);
    }
    .toc thead th {
        border-bottom-width: 2px;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .toc-day {
        white-space: nowrap;
        font-weight: 600;
    }
    .toc-links {
        white-space: nowrap;
    }
</style>
