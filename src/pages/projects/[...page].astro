---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import ProjectPreview from '../../components/ProjectPreview.astro';
import siteConfig from '../../data/site-config';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
    return paginate(projects, { pageSize: siteConfig.projectsPerPage || 10 });
}

type Props = { page: Page<CollectionEntry<'projects'>> };

const { page } = Astro.props;
const portfolio = page.data;
---

<BaseLayout
    title="Research"
    description="Research in industrial organization, experimental economics, and machine learning in economic theory."
>
    <section class="page-hero">
        <div class="container">
            <p class="eyebrow">Industrial organization · Experimental · ML in theory</p>
            <h1>Research</h1>
            <p>
                My work studies how firms behave strategically in imperfectly competitive markets, how people
                actually decide under risk, and where machine learning can sharpen economic theory.
            </p>
        </div>
    </section>

    <section class="section" style="padding-top: 2rem;">
        <div class="container">
            <div class="research-list">
                {portfolio.map((project) => <ProjectPreview project={project} class="reveal" />)}
            </div>
            <Pagination page={page} class="reveal" style="margin-top: 2rem;" />
            <p class="note" style="margin-top: 2rem;">
                Working papers and drafts available on request — see <a href="/contact">contact</a>.
            </p>
        </div>
    </section>
</BaseLayout>
