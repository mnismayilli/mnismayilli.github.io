---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import PostPreview from '../../components/PostPreview.astro';
import siteConfig from '../../data/site-config';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
    return paginate(posts, { pageSize: siteConfig.postsPerPage || 10 });
}

type Props = { page: Page<CollectionEntry<'blog'>> };

const { page } = Astro.props;
const blog = page.data;
---

<BaseLayout title="Blog" description="Notes and writing by Mehman Ismayilli.">
    <section class="page-hero">
        <div class="container">
            <p class="eyebrow">Writing</p>
            <h1>Blog</h1>
        </div>
    </section>

    <section class="section" style="padding-top: 2rem;">
        <div class="container">
            <div class="research-list">
                {blog.map((post) => <PostPreview post={post} class="reveal" />)}
            </div>
            <Pagination page={page} class="reveal" style="margin-top: 2rem;" />
        </div>
    </section>
</BaseLayout>
