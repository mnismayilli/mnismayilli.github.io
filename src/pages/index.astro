---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EquilibriumMotif from '../components/EquilibriumMotif.astro';
import siteConfig from '../data/site-config';
import { sortItemsByDateDesc } from '../utils/data-utils';

const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
const featured = projects.filter(({ data }) => data.isFeatured);

const kindOf = (text = '') => (/experiment|behaviou?r|framing|risk/i.test(text) ? 'experimental' : 'theory');

const sections = [
    {
        kicker: 'Teaching',
        title: 'Courses & supervision',
        body: 'Microeconomics and financial econometrics at Oxford and SJTU, with problem sets and assessments.',
        foot: 'EC107 · EC306 · FI362',
        href: '/teaching'
    },
    {
        kicker: 'Lecture Notes',
        title: 'Slides, supplements & data',
        body: 'Lecture slides, hands-on R supplements, and problem sets, added as each course runs.',
        foot: 'Open access',
        href: '/lectures'
    },
    {
        kicker: 'M&A Watch',
        title: 'Merger tracker',
        body: 'Live competition-authority merger reviews, synced weekly from official OECD public registers.',
        foot: 'Updated weekly',
        href: '/ma-watch'
    }
];
---

<BaseLayout description={siteConfig.description} image={siteConfig.image}>
    <!-- HERO -->
    <section class="hero">
        <div class="container hero-grid">
            <div>
                <h1>Mehman Ismayilli</h1>
                <p class="hero-title">
                    <span class="hero-mark">Economist &amp; Educator</span> at the
                    <a href="https://www.economics.ox.ac.uk/people/mehman-ismayilli" rel="noopener">University of Oxford</a>
                </p>
                <p class="hero-lede">
                    Lecturer in Economics at the University of Oxford. My research interests are industrial
                    organization, experimental economics, and the application of machine learning in economic
                    theory. Previously, I worked at the University of Manchester and the University of Warwick.
                    I hold my PhD in Economics from the University of Leicester.
                </p>
                <div class="cta-row">
                    <a class="btn btn--primary" href="/about">View CV <span class="arrow">→</span></a>
                    <a class="btn" href="/projects">Research</a>
                    <a class="btn" href="/contact">Contact</a>
                </div>
            </div>

            <figure class="hero-figure">
                <EquilibriumMotif />
                <img class="hero-photo" src="/profilephoto.jpg" alt="Mehman Ismayilli" width="270" height="302" />
            </figure>
        </div>
    </section>

    <!-- RESEARCH -->
    {
        featured.length > 0 && (
            <section class="section" id="research">
                <div class="container">
                    <div class="section-head reveal">
                        <div>
                            <p class="eyebrow">Selected work</p>
                            <h2>Research</h2>
                        </div>
                        <a class="section-link" href="/projects">
                            All research <span class="arrow">→</span>
                        </a>
                    </div>

                    <div class="research-list">
                        {featured.map((r) => {
                            const kind = kindOf(`${r.data.title} ${r.data.description ?? ''}`);
                            return (
                                <a class="research-item reveal" href={`/projects/${r.id}/`}>
                                    <span class="research-tag" data-kind={kind}>
                                        <span class="dot" />
                                        {kind}
                                    </span>
                                    <div class="research-body">
                                        <h3>{r.data.title}</h3>
                                        {r.data.description && <p>{r.data.description}</p>}
                                    </div>
                                    <span class="research-go" aria-hidden="true">→</span>
                                </a>
                            );
                        })}
                    </div>
                </div>
            </section>
        )
    }

    <!-- SECTIONS -->
    <section class="section">
        <div class="container">
            <div class="section-head reveal">
                <div>
                    <p class="eyebrow">Beyond research</p>
                    <h2>Teaching &amp; notes</h2>
                </div>
            </div>

            <div class="card-grid">
                {
                    sections.map((s) => (
                        <a class="card reveal" href={s.href}>
                            <span class="card-kicker">{s.kicker}</span>
                            <h3>{s.title}</h3>
                            <p>{s.body}</p>
                            <span class="card-foot">{s.foot}</span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>
</BaseLayout>
