---
import siteConfig from '../data/site-config';

const year = new Date().getFullYear();
const siteLinks = siteConfig.headerNavLinks || [];
const profileLinks = siteConfig.footerNavLinks || [];
const social = siteConfig.socialLinks || [];

// Oxford goes in the Profile column; the rest (LinkedIn, X) go under Elsewhere.
const oxford = social.find((l) => /oxford/i.test(l.text));
const elsewhere = social.filter((l) => !/oxford/i.test(l.text));
---

<footer class="site-footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-brand">
                <span class="brand"><span class="brand-dot"></span>{siteConfig.title}</span>
                <p>
                    Lecturer in Economics, University of Oxford. Industrial organization, experimental
                    economics, and machine learning in economic theory.
                </p>
            </div>

            <div class="footer-links">
                <div class="footer-col">
                    <h4>Site</h4>
                    {siteLinks.map((l) => <a href={l.href} set:html={l.text} />)}
                </div>
                <div class="footer-col">
                    <h4>Profile</h4>
                    {profileLinks.map((l) => <a href={l.href}>{l.text}</a>)}
                    {oxford && <a href={oxford.href} rel="noopener">Oxford</a>}
                </div>
                <div class="footer-col">
                    <h4>Elsewhere</h4>
                    {elsewhere.map((l) => <a href={l.href} rel="noopener">{l.text}</a>)}
                </div>
            </div>
        </div>

        <div class="footer-base">
            <span>&copy; {year} {siteConfig.title}</span>
            <span>Built with Astro · Oxford, UK</span>
        </div>
    </div>
</footer>
