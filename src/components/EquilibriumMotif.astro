---
// Signature element: a supply–demand coordinate plane with a marked
// equilibrium point. A nod to industrial organization / microeconomic theory.
---
<svg class="hero-motif" viewBox="0 0 260 260" role="img"
     aria-label="A supply and demand diagram with a marked equilibrium point">
  <!-- faint grid -->
  <g class="motif-grid">
    <line x1="40" y1="65"  x2="240" y2="65"  />
    <line x1="40" y1="120" x2="240" y2="120" />
    <line x1="40" y1="175" x2="240" y2="175" />
    <line x1="95"  y1="20" x2="95"  y2="230" />
    <line x1="150" y1="20" x2="150" y2="230" />
    <line x1="205" y1="20" x2="205" y2="230" />
  </g>

  <!-- axes -->
  <g class="motif-axis">
    <line x1="40" y1="20" x2="40" y2="230" />
    <line x1="40" y1="230" x2="240" y2="230" />
  </g>

  <!-- equilibrium guide lines -->
  <line class="motif-eq-line" x1="140" y1="130" x2="140" y2="230" />
  <line class="motif-eq-line" x1="40"  y1="130" x2="140" y2="130" />

  <!-- curves -->
  <path class="motif-curve motif-demand" d="M55,45 C110,92 150,145 225,212" />
  <path class="motif-curve motif-supply" d="M55,212 C110,162 152,108 225,45" />

  <!-- equilibrium point -->
  <circle class="motif-eq" cx="140" cy="130" r="5.5" />

  <!-- labels -->
  <text class="motif-label" x="26" y="134">p*</text>
  <text class="motif-label" x="135" y="246">q*</text>
  <text class="motif-label" x="228" y="210">D</text>
  <text class="motif-label" x="228" y="50">S</text>
</svg>
