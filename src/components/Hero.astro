---
import { marked } from 'marked';
import siteConfig from '../data/site-config';
import Button from './Button.astro';

const hero = siteConfig.hero;
const research = siteConfig.research;
---

{
    (hero?.title || hero?.image?.src || hero?.text || (hero?.actions && hero.actions.length > 0)) && (
        <section class="w-full mb-16 sm:mb-24">
            <div class="flex flex-col items-center text-center gap-4">
                {hero.image?.src && (
                    <figure class="mb-1">
                        <img
                            class="w-36 h-36 sm:w-44 sm:h-44 object-cover object-top rounded-full shadow-md border border-black/10 dark:border-white/10"
                            src={hero.image.src}
                            loading="eager"
                            decoding="async"
                            alt={hero.image.alt || ''}
                        />
                    </figure>
                )}
                <div class="flex flex-col items-center gap-1">
                    <h1 class="text-3xl leading-tight font-serif font-medium sm:text-4xl">{siteConfig.title}</h1>
                    {siteConfig.subtitle && (
                        <p class="text-sm opacity-60">{siteConfig.subtitle}</p>
                    )}
                    <hr class="w-16 border-current opacity-20 mt-2" />
                </div>
                {hero.text && (
                    <div class="max-w-2xl prose sm:prose-lg text-left" set:html={marked.parse(hero.text)} />
                )}
                {research && (
                    <div class="max-w-2xl prose sm:prose-lg text-left">
                        <strong>Research Interests:</strong> {research}
                    </div>
                )}
                {hero.actions && hero.actions.length > 0 && (
                    <div class="flex flex-wrap justify-center gap-3 mt-2">
                        {hero.actions.map((action) => (
                            <Button href={action.href}>{action.text}</Button>
                        ))}
                    </div>
                )}
            </div>
        </section>
    )
}
