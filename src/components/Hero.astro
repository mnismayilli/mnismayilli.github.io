---
import { marked } from 'marked';
import siteConfig from '../data/site-config';
import Button from './Button.astro';

const hero = siteConfig.hero;
const research = siteConfig.research;
---

{
    (hero?.title || hero?.image?.src || hero?.text || (hero?.actions && hero.actions.length > 0)) && (
        <section class="mb-16 w-full sm:mb-24">
            <div class="flex flex-col items-center gap-5 text-center">
                {hero.image?.src && (
                    <figure class="relative">
                        <div class="absolute -inset-1 rounded-full bg-accent-soft blur-md" aria-hidden="true" />
                        <img
                            class="relative h-36 w-36 rounded-full border-4 border-white object-cover object-top shadow-[var(--shadow-card-hover)] ring-1 ring-black/5 sm:h-44 sm:w-44"
                            src={hero.image.src}
                            loading="eager"
                            decoding="async"
                            alt={hero.image.alt || ''}
                        />
                    </figure>
                )}
                <div class="flex flex-col items-center gap-2">
                    <h1 class="font-serif text-3xl leading-tight font-medium tracking-tight text-strong sm:text-5xl">
                        {siteConfig.title}
                    </h1>
                    {siteConfig.subtitle && <p class="text-sm font-medium tracking-wide text-soft sm:text-base">{siteConfig.subtitle}</p>}
                    <hr class="mt-2 h-px w-16 border-0 bg-accent/40" />
                </div>
                {hero.text && <div class="prose max-w-2xl text-left sm:prose-lg" set:html={marked.parse(hero.text)} />}
                {research && (
                    <div class="prose max-w-2xl text-left sm:prose-lg">
                        <strong>Research Interests:</strong> {research}
                    </div>
                )}
                {hero.actions && hero.actions.length > 0 && (
                    <div class="mt-3 flex flex-wrap justify-center gap-3">
                        {hero.actions.map((action, i) => (
                            <Button href={action.href} variant={i === 0 ? 'solid' : 'outline'}>
                                {action.text}
                            </Button>
                        ))}
                    </div>
                )}
            </div>
        </section>
    )
}
