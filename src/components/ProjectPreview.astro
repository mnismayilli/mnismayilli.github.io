---
import { type CollectionEntry } from 'astro:content';

type Props = { project: CollectionEntry<'projects'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, description } = project.data;
const TitleTag = headingLevel;
const kind = /experiment|behaviou?r|framing|risk/i.test(`${title} ${description ?? ''}`) ? 'experimental' : 'theory';
---

<a class:list={['research-item', className]} href={`/projects/${project.id}/`}>
    <span class="research-tag" data-kind={kind}><span class="dot"></span>{kind}</span>
    <div class="research-body">
        <TitleTag>{title}</TitleTag>
        {description && <p>{description}</p>}
    </div>
    <span class="research-go" aria-hidden="true">→</span>
</a>
