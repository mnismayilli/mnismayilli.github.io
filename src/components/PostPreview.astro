---
import { type CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

type Props = {
    post: CollectionEntry<'blog'> | CollectionEntry<'lectures'>;
    class?: string;
    headingLevel?: 'h2' | 'h3';
    urlPrefix?: string;
};

const { post, class: className, headingLevel = 'h2', urlPrefix = '/blog' } = Astro.props;
const { title, publishDate } = post.data;
const excerpt = 'excerpt' in post.data ? post.data.excerpt : 'description' in post.data ? post.data.description : undefined;
const TitleTag = headingLevel;
---

<a class:list={['research-item', className]} href={`${urlPrefix}/${post.id}/`}>
    <span class="research-tag"><span class="dot"></span><FormattedDate date={publishDate} /></span>
    <div class="research-body">
        <TitleTag>{title}</TitleTag>
        {excerpt && <p>{excerpt}</p>}
    </div>
    <span class="research-go" aria-hidden="true">→</span>
</a>
